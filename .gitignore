__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.env

# Original source files are preserved locally but can include victim names,
# source notes, URLs, and other details unsuitable for public publishing.
data/raw/*
!data/raw/README.md
data/raw/external/
data/processed/
reports/*.json
reports/*.csv

# Generated public artifacts can be rebuilt from raw data.
data/public/*.csv
data/public/*.sqlite
data/public/*.db
data/public/schema.json

# Hidden, sensitive, restricted, or license-unclear data must stay local.
data/private/
data/media_attachments/

# Frontend local dependencies and generated build output.
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/*.tsbuildinfo

# Local editor and demo-server scratch files.
.vscode/
*.code-workspace
.mkdocs-demo.*

# MkDocs generated GitHub Pages output.
site/
